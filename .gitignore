# Ignorar plugins (geralmente instalados via painel ou WP-CLI)
wp-content/plugins/*
# Se quiser versionar um plugin específico, use: !wp-content/plugins/meu-plugin-proprio/

# Ignorar temas padrão
wp-content/themes/twenty*/

